<Window x:Class="demo.TaskManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F0F8FF">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="📋 Cybersecurity Task Manager" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Task List -->
        <ListView Grid.Row="1" x:Name="taskListView" Margin="0,0,0,10"
                  SelectionMode="Single" MouseDoubleClick="TaskDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Status" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsCompleted, Converter={StaticResource BoolToStatus}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Title" Width="200" DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="Description" Width="180" DisplayMemberBinding="{Binding Description}"/>
                    <GridViewColumn Header="Reminder" Width="120" DisplayMemberBinding="{Binding ReminderDate, StringFormat={}{0:yyyy-MM-dd}}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="➕ Add Task" Height="35" Width="120" Margin="5"
                    Click="AddTask" Background="LightGreen" FontWeight="Bold"/>
            <Button Content="✅ Complete" Height="35" Width="100" Margin="5"
                    Click="CompleteTask" Background="DodgerBlue" Foreground="White" FontWeight="Bold"/>
            <Button Content="🗑️ Delete" Height="35" Width="100" Margin="5"
                    Click="DeleteTask" Background="Red" Foreground="White" FontWeight="Bold"/>
            <Button Content="🔄 Refresh" Height="35" Width="100" Margin="5"
                    Click="RefreshTasks" Background="Gray" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
