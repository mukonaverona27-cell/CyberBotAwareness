<Window x:Class="demo.QuizManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Quiz" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0FFF0">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="🎯 Cybersecurity Quiz" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text=" | Score: " FontSize="16" Margin="20,0,0,0"/>
            <TextBlock x:Name="scoreText" Text="0/0" FontSize="16" FontWeight="Bold" Foreground="Green"/>
        </StackPanel>

        <!-- Progress -->
        <TextBlock Grid.Row="1" x:Name="progressText" Text="Question 0 of 0" 
                   HorizontalAlignment="Center" FontSize="14" Margin="0,5"/>

        <!-- Question Area -->
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="2" 
                CornerRadius="10" Padding="15" Background="White" Margin="0,10">
            <StackPanel>
                <TextBlock x:Name="questionText" Text="Click 'Start Quiz' to begin!" 
                           FontSize="16" TextWrapping="Wrap" Margin="0,0,0,20"/>

                <ItemsControl x:Name="optionsList" Margin="0,0,0,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Content="{Binding}" GroupName="Options" 
                                         Margin="0,3" FontSize="14"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="feedbackText" Text="" FontSize="14" 
                           TextWrapping="Wrap" Foreground="Blue" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button x:Name="startBtn" Content="▶ Start Quiz" Height="35" Width="120" Margin="5"
                    Click="StartQuiz" Background="LightGreen" FontWeight="Bold"/>
            <Button x:Name="nextBtn" Content="Next →" Height="35" Width="100" Margin="5"
                    Click="NextQuestion" IsEnabled="False" Background="DodgerBlue" 
                    Foreground="White" FontWeight="Bold"/>
            <Button Content="🔄 Reset" Height="35" Width="100" Margin="5"
                    Click="ResetQuiz" Background="Gray" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- Summary -->
        <Border Grid.Row="4" x:Name="summaryPanel" Visibility="Collapsed" 
                BorderBrush="Gold" BorderThickness="2" CornerRadius="10" 
                Padding="15" Background="LightYellow" Margin="0,10">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock x:Name="summaryText" Text="" FontSize="16" FontWeight="Bold"/>
                <Button Content="Close" Height="30" Width="80" Margin="0,10,0,0"
                        Click="CloseQuiz" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>